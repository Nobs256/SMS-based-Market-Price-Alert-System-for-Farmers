<?php require_once __DIR__ . '/../partials/header.phtml'; ?>

<div class="page-header">
    <h1><?php echo ucfirst(str_replace('-', ' ', $page)); ?></h1>
</div>

<?php // Display and clear the status message from the session
    if (isset($_SESSION['status'])) {
        $status = $_SESSION['status'];
        
        echo "<div class='status-message {$status['type']}'>" . htmlspecialchars($status['message']) . "</div>";
        unset($_SESSION['status']);
    }
    
    // Include the correct view partial based on the page
    $partialPath = __DIR__ . "/partials/_{$page}.phtml";
    if (file_exists($partialPath)) {
        require_once $partialPath;
    } else {
        echo "<div class='status-message error'>Error: Page not found.</div>";
    }
?>

<?php require_once __DIR__ . '/../partials/footer.phtml'; ?>