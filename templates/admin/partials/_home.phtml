<!-- Farmer Statistics Chart -->
<div class="form-section">
    <h2>Farmer Language Distribution</h2>
    <div style="width: 75%; max-width: 400px; margin: auto;">
        <canvas id="farmerLangChart"></canvas>
    </div>
</div>

<!-- Manual Broadcast Section -->
<div class="form-section">
    <h2>Manual SMS Broadcast</h2>
    <p>Click the button below to immediately send the latest market prices to all registered farmers. This uses the most recently entered prices for each market.</p>
    <form action="broadcast.php" method="post" onsubmit="return confirm('Are you sure you want to send an SMS to all <?php echo $totalFarmers; ?> registered farmers right now?');">
        <button type="submit" name="broadcast_now" class="broadcast-btn">
            Broadcast Prices Now
        </button>
    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const ctx = document.getElementById('farmerLangChart').getContext('2d');
    const farmerStats = <?php echo $farmerStatsJson; ?>;

    const labels = Object.keys(farmerStats).map(lang => {
        if (lang === 'en') return 'English';
        if (lang === 'ruk') return 'Rukiga';
        return lang; // Fallback
    });
    const data = Object.values(farmerStats);

    new Chart(ctx, {
        type: 'pie',
        data: {
            labels: labels,
            datasets: [{
                label: 'Number of Farmers',
                data: data,
                backgroundColor: ['#3498DB', '#1ABC9C', '#F1C40F', '#E74C3C'],
                hoverOffset: 4
            }]
        }
    });
});
</script>